---
const desktopImage = "/images/hero-mountain-waystation.png";
const mobileImage = "/images/hero-mountain-waystation-mobile.png";
const heroAlt = "A Rangeway location at dusk with sunset-lit mountains behind, lounge interior glowing through the glass facade, and a Rivian charging under the timber canopy";
---

<section class="hero">
  <div class="hero__grid">
    <div class="hero__text">
      <p class="hero__kicker"><span class="hero__kicker-mark"></span>America's First Hospitality-Driven EV Charging Network</p>
      <h1 class="hero__headline">Travel Farther,<br />Stop Better.</h1>
      <p class="hero__lede">
        Hospitality operators run every location, and the stop, not the charger, is the point.
      </p>
      <div class="hero__ctas">
        <a class="btn btn-warm" href="/network">
          Discover the Network
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </a>
        <a class="btn btn-ghost" href="/our-story">Our Story</a>
      </div>
    </div>

    <figure class="hero__media frame">
      <picture>
        <source media="(max-width: 720px)" srcset={mobileImage} />
        <img src={desktopImage} alt={heroAlt} fetchpriority="high" />
      </picture>
    </figure>

    <span class="hero__mark" aria-hidden="true"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-ink);
    color: var(--color-cream);
    border-bottom: var(--rule-bold) solid var(--color-ink);
    padding-top: var(--nav-height);
    isolation: isolate;
  }

  .hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    min-height: calc(100svh - var(--nav-height));
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(20px, 2.6vw, 32px);
    padding: clamp(48px, 6vw, 96px) clamp(40px, 5vw, 88px) clamp(48px, 6vw, 96px) clamp(20px, 4vw, 56px);
  }

  .hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 241, 235, 0.84);
    max-width: 40ch;
    line-height: 1.5;
  }

  .hero__kicker-mark {
    flex: none;
    width: 14px;
    height: 14px;
    background: var(--color-warm);
    border: var(--rule) solid var(--color-warm);
  }

  .hero__headline {
    margin: 0;
    color: var(--color-cream);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2.9rem, 6.4vw, 5.6rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .hero__lede {
    margin: 0;
    max-width: 42ch;
    padding-top: var(--space-4);
    border-top: var(--rule) solid rgba(245, 241, 235, 0.28);
    font-size: clamp(1.06rem, 1.3vw, 1.22rem);
    line-height: 1.6;
    color: rgba(245, 241, 235, 0.82);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    margin-top: var(--space-2);
  }

  .hero__media {
    position: relative;
    border: 0;
    border-left: var(--rule-bold) solid var(--color-ink);
    background: var(--color-ink);
    overflow: hidden;
    margin: 0;
  }

  .hero__media picture {
    display: block;
    height: 100%;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  /* Big amber geometric punctuation straddling the seam */
  .hero__mark {
    position: absolute;
    left: calc(54% - clamp(44px, 5vw, 70px));
    bottom: clamp(40px, 7vw, 96px);
    width: clamp(88px, 11vw, 140px);
    height: clamp(88px, 11vw, 140px);
    border-radius: 999px;
    background: var(--color-warm);
    border: var(--rule-bold) solid var(--color-ink);
    z-index: 3;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .hero__text {
      padding: clamp(40px, 9vw, 72px) clamp(20px, 6vw, 40px);
      order: 1;
    }

    .hero__media {
      order: 2;
      border-left: 0;
      border-top: var(--rule-bold) solid var(--color-ink);
      aspect-ratio: 16 / 11;
    }

    .hero__mark {
      left: auto;
      right: clamp(20px, 6vw, 40px);
      bottom: auto;
      top: calc(100% - clamp(44px, 9vw, 60px));
      width: clamp(72px, 16vw, 96px);
      height: clamp(72px, 16vw, 96px);
    }

    .hero__headline {
      font-size: clamp(3rem, 15vw, 5.4rem);
    }
  }
</style>
