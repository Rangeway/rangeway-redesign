---
---

<section id="comfort" class="comfort section-dark">
  <div class="comfort__media">
    <img src="/images/basecamp-interior.jpg" alt="Interior of a Rangeway driver's lounge with warm lighting and comfortable seating" loading="lazy" />
    <div class="comfort__scrim"></div>
  </div>
  <div class="container comfort__inner">
    <div class="comfort__text reveal">
      <p class="eyebrow eyebrow-muted">Inside the network</p>
      <h2>The Indoor Comfort Guarantee.</h2>
      <p class="comfort__body">
        Every Waystation and Basecamp commits to climate-controlled indoor comfort, with
        comfortable restrooms, generous seating, and reliable high-speed Wi-Fi. The lounge is part
        of the standard, not an upsell.
      </p>
      <p class="comfort__body">
        At Summits, the hospitality extends further still, into overnight stays in modular
        Lookouts.
      </p>
    </div>
  </div>
</section>

<style>
  .comfort {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(132px, 16vw, 220px) 0 clamp(94px, 12vw, 164px);
  }

  .comfort__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .comfort__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
  }

  .comfort__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(23, 21, 20, 0.92) 0%, rgba(23, 21, 20, 0.58) 48%, rgba(23, 21, 20, 0.2) 100%),
      linear-gradient(180deg, rgba(23, 21, 20, 0.12) 0%, rgba(23, 21, 20, 0.68) 100%),
      radial-gradient(circle at 78% 16%, rgba(244, 168, 85, 0.2), transparent 44%);
  }

  .comfort__text {
    max-width: 620px;
    color: var(--color-cream);
    padding-left: clamp(20px, 3vw, 42px);
    border-left: 3px solid var(--color-warm);
  }

  .comfort__body {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: 0.9;
    margin-top: var(--space-5);
  }

  .comfort__body + .comfort__body {
    margin-top: var(--space-4);
  }

  .comfort__text .eyebrow {
    color: var(--color-warm);
  }

  @media (max-width: 720px) {
    .comfort__scrim {
      background: linear-gradient(
        180deg,
        rgba(23, 21, 20, 0.6) 0%,
        rgba(23, 21, 20, 0.88) 60%
      );
    }
  }
</style>
