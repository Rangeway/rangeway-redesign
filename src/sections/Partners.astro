---
---

<section class="partners section section-sage">
  <div class="container partners__inner reveal">
    <p class="eyebrow">Built with</p>
    <h2>The partners behind the network.</h2>
    <p class="partners__lede">
      Rangeway is operated by a small team and built with specialist partners across structure,
      energy, software, and driver experience. Every destination comes together through people who
      are the best at what they do.
    </p>
    <a class="btn-link partners__cta" href="/partners">
      See all partners
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="13 6 19 12 13 18" />
      </svg>
    </a>
  </div>
</section>

<style>
  .partners__inner {
    max-width: none;
    display: grid;
    grid-template-columns: minmax(260px, 0.65fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 92px);
    align-items: start;
  }

  .partners__lede {
    margin-top: 0;
    color: var(--color-cream);
    font-size: 1.1rem;
    line-height: 1.75;
    padding-top: var(--space-5);
    border-top: var(--rule-bold) solid var(--color-cream);
  }

  .partners__lede a {
    color: var(--color-warm);
    font-weight: 700;
    border-bottom: var(--rule) solid var(--color-warm);
    padding-bottom: 1px;
    transition: color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard);
  }

  .partners__lede a:hover {
    color: var(--color-warm);
    opacity: 0.8;
  }

  .partners__cta {
    margin-top: var(--space-6);
    grid-column: 2;
  }

  .partners__inner .eyebrow,
  .partners__inner h2 {
    grid-column: 1;
  }

  .partners__lede {
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  @media (max-width: 820px) {
    .partners__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .partners__lede,
    .partners__cta {
      grid-column: 1;
      grid-row: auto;
    }
  }
</style>
