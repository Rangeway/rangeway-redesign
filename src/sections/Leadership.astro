---
const leaders = [
  {
    name: "Zak Winnick",
    role: "Founder and CEO",
    bio: "Zak has spent his career operating luxury resorts and flagship hotels, and has long been an EV driver and community leader.",
    photo: "/images/team/zak-winnick.jpg",
    linkedin: "https://www.linkedin.com/in/zakwinnick"
  },
  {
    name: "Luke Schüette",
    role: "Director of Design and Construction",
    bio: "Luke designs Rangeway's solar canopies and lounge structures, and chairs ASTM's task group on Structural Engineered Bamboo.",
    photo: "/images/team/luke-schuette.jpg",
    linkedin: "https://www.linkedin.com/in/luke-d-sch%C3%BCette/"
  },
  {
    name: "Theo Reichgelt",
    role: "Brand and Growth",
    bio: "Theo founded Nexxt Industry and hosts The eMobility Marketing Podcast.",
    photo: "/images/team/theo-reichgelt.jpg",
    linkedin: "https://www.linkedin.com/in/theoreichgelt/"
  },
  {
    name: "James Regan",
    role: "Finance and Strategy",
    bio: "James has built his career in corporate development and infrastructure project financing, and serves as Managing Partner at CapitalWorks.",
    photo: "/images/team/james-regan.jpg",
    linkedin: "https://www.linkedin.com/in/james-regan-913915a/"
  },
  {
    name: "Stephanie McGreevy",
    role: "Policy and Public Capital",
    bio: "Stephanie specializes in ZEV infrastructure and founded Open Energy Alliance.",
    photo: "/images/team/stephanie-mcgreevy.jpg",
    linkedin: "https://www.linkedin.com/in/smcgreevy/"
  }
];
---

<section class="leadership section">
  <div class="container">
    <div class="leadership__heading reveal">
      <p class="eyebrow">Leadership</p>
      <h2>The people building Rangeway.</h2>
      <p class="leadership__lede">
        Hospitality operators, energy veterans, and EV community organizers.
      </p>
    </div>

    <ul class="leadership__grid">
      {leaders.map((l) => (
        <li class="leader reveal">
          <div class="leader__photo">
            <img src={l.photo} alt={`Portrait of ${l.name}`} loading="lazy" />
          </div>
          <div class="leader__body">
            <h3 class="leader__name">{l.name}</h3>
            <p class="leader__role">{l.role}</p>
            <p class="leader__bio">{l.bio}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="leadership__cta reveal">
      <a class="btn-link" href="/team">
        Meet the full team
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .leadership__heading {
    max-width: 620px;
    margin-bottom: var(--space-7);
  }

  .leadership__lede {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  .leadership__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-top: var(--rule-bold) solid var(--color-ink);
  }

  .leader {
    display: grid;
    grid-template-columns: 104px minmax(180px, 0.5fr) minmax(0, 1fr);
    gap: clamp(18px, 3vw, 44px);
    padding: var(--space-5) 0;
    border-bottom: var(--rule) solid var(--color-ink);
    align-items: center;
    transition: transform var(--dur-fast) var(--ease-standard);
  }

  .leader:hover {
    transform: translateX(6px);
  }

  .leader__photo {
    width: 88px;
    height: 88px;
    border: var(--rule) solid var(--color-ink);
    overflow: hidden;
    background: var(--surface-alt);
  }

  .leader__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .leader__body {
    display: grid;
    grid-template-columns: minmax(180px, 0.5fr) minmax(0, 1fr);
    grid-column: 2 / -1;
    align-items: center;
    gap: clamp(18px, 3vw, 44px);
  }

  .leader__name {
    font-size: clamp(1.25rem, 2.6vw, 2.1rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .leader__role {
    font-family: var(--font-heading);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-warm-deep);
    font-weight: 600;
    margin: var(--space-2) 0 0;
  }

  .leader__bio {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  .leadership__cta {
    margin-top: var(--space-7);
  }

  @media (max-width: 760px) {
    .leader,
    .leader__body {
      grid-template-columns: 82px minmax(0, 1fr);
      gap: var(--space-4);
    }

    .leader__photo {
      width: 72px;
      height: 72px;
    }

    .leader__bio {
      grid-column: 1 / -1;
    }
  }
</style>
