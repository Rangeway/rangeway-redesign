---
const formats = [
  {
    name: "Waystation",
    tagline: "Streamlined comfort",
    description:
      "Ultra-fast charging paired with a climate-controlled driver's lounge, comfortable restrooms, generous seating, and high-speed Wi-Fi. The heart of the network.",
    image: "/images/waystation-joshua-tree.jpg",
    imageAlt: "A Waystation nestled into the Joshua Tree landscape",
    href: "/network/waystation"
  },
  {
    name: "Basecamp",
    tagline: "The full-service destination",
    description:
      "Ultra-fast charging, a staffed driver's lounge, and a staffed cafe. Our flagship experience on high-traffic corridors.",
    image: "/images/basecamp-hero-desert.jpg",
    imageAlt: "A Basecamp at dusk with a lit lounge, charging canopy, and desert mountains behind",
    href: "/network/basecamp"
  },
  {
    name: "Summit",
    tagline: "Where the road meets rest",
    description:
      "Modular Lookouts, a central clubhouse, and fully off-grid solar charging. A hospitality-first destination where the stop becomes the journey.",
    image: "/images/summit-1.jpg",
    imageAlt: "A Summit Lookout framed by the desert at dusk",
    href: "/network/summit"
  }
];
---

<section id="network" class="section network">
  <div class="container">
    <div class="network__heading reveal">
      <p class="eyebrow">The Network</p>
      <h2>Three formats. One unwavering standard.</h2>
      <p class="network__lede">
        Every Rangeway location shares the same hospitality DNA. The scale shifts with the corridor,
        the community, and the journey.
      </p>
    </div>

    <div class="network__grid">
      {formats.map((f, i) => (
        <a class="network-format reveal" href={f.href}>
          <span class="network-format__num">0{i + 1}</span>
          <div class="network-format__media">
            <img src={f.image} alt={f.imageAlt} loading="lazy" />
          </div>
          <div class="network-format__body">
            <p>{f.tagline}</p>
            <h3>{f.name}</h3>
            <span class="network-format__description">{f.description}</span>
          </div>
          <span class="network-format__arrow" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="13 6 19 12 13 18" />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="network__cta reveal">
      <a class="btn btn-primary" href="/network">
        Explore all three formats
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .network__heading {
    max-width: 780px;
    margin-bottom: clamp(44px, 7vw, 96px);
  }

  .network__lede {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  .network__grid {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border-strong);
  }

  .network-format {
    display: grid;
    grid-template-columns: 76px minmax(220px, 0.64fr) minmax(0, 1fr) 52px;
    gap: clamp(18px, 3vw, 42px);
    align-items: center;
    padding: clamp(22px, 4vw, 48px) 0;
    border-bottom: 1px solid var(--color-border-strong);
    color: var(--color-text);
  }

  .network-format:hover {
    color: var(--color-text);
  }

  .network-format__num {
    align-self: stretch;
    display: flex;
    align-items: flex-start;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-warm-deep);
  }

  .network-format__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--surface-alt);
  }

  .network-format__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .network-format:hover .network-format__media img {
    transform: scale(1.045);
  }

  .network-format__body {
    display: grid;
    grid-template-columns: minmax(120px, 0.45fr) minmax(0, 0.75fr) minmax(220px, 1fr);
    gap: clamp(18px, 3vw, 38px);
    align-items: baseline;
  }

  .network-format__body p {
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--color-warm-deep);
  }

  .network-format__body h3 {
    font-size: clamp(2rem, 4.2vw, 4.3rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .network-format__description {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .network-format__arrow {
    width: 52px;
    height: 52px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-charcoal);
    transition: background var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }

  .network-format:hover .network-format__arrow {
    background: var(--color-warm);
    transform: translateX(4px);
  }

  .network__cta {
    margin-top: var(--space-7);
    display: flex;
    justify-content: flex-start;
  }

  @media (max-width: 1050px) {
    .network-format {
      grid-template-columns: 48px minmax(180px, 0.7fr) minmax(0, 1fr);
    }

    .network-format__body {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .network-format__arrow {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .network-format {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .network-format__num {
      align-items: center;
    }

    .network-format__media {
      order: -1;
    }
  }
</style>
