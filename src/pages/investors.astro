---
import SiteLayout from "../layouts/SiteLayout.astro";
import { EXTERNAL_LINKS, FORMATS, PROJECTS } from "../data/site-content";

const thesis = [
  ["An open category", "Public charging is commonly designed around the vehicle. Rangeway competes on the experience of the people inside it."],
  ["Dwell time, reconsidered", "Time at a charger can support useful amenities, stronger loyalty, and a differentiated roadside brand."],
  ["Experience as the moat", "Hardware and electricity can commoditize. Consistently operating a place that feels hospitable is harder to reproduce."],
  ["Three formats, one standard", "Waystation, Basecamp, and Summit adapt the same hospitality promise to regional routes, major corridors, and destinations."],
];
---

<SiteLayout title="Investors · Rangeway" description="Rangeway's hospitality-led EV charging thesis, public project pipeline, and investor contact." class="investor-family">
  <section class="investor-proof-opening">
    <div class="investor-proof-opening__thesis">
      <p class="eyebrow">Investors / Rangeway</p>
      <h1>A charging stop is a hospitality business.</h1>
      <p>Rangeway is building a hospitality brand for EV drivers. Charging is the entry point; the experience around it is the business.</p>
      <div class="button-row"><a class="button button--sun" href={EXTERNAL_LINKS.investorHub} target="_blank" rel="noopener noreferrer">Visit Investor Hub</a><a class="button" href="mailto:investors@rangeway.co?subject=Investor%20Briefing%20Request">Email investors</a></div>
    </div>
    <dl class="investor-evidence-rail" aria-label="Public operating evidence">
      <div><dt>Formats</dt><dd><strong>03</strong><span>Waystation / Basecamp / Summit</span></dd></div>
      <div><dt>Public regions</dt><dd><strong>03</strong><span>Bozeman / Mojave / St. Louis</span></dd></div>
      <div><dt>Company activity</dt><dd><strong>Now</strong><span>Developing / partnering / raising</span></dd></div>
    </dl>
  </section>

  <section class="investor-thesis">
    <header><p>The thesis</p><h2>Experience changes the category.</h2></header>
    <div>{thesis.map(([title, body], index) => <article><span>0{index + 1}</span><h3>{title}</h3><p>{body}</p></article>)}</div>
  </section>

  <section class="investor-evidence">
    <div class="investor-evidence__title"><p>Operating evidence</p><h2>Built around work already underway.</h2></div>
    <div class="investor-evidence__facts">
      <p>Rangeway is actively designing, developing, publishing, partnering, raising, and hiring. Its first locations remain in development.</p>
      <div>{FORMATS.map((format) => <article><strong>{format.name}</strong><span>{format.context}</span><p>{format.operatingModel}</p></article>)}</div>
    </div>
  </section>

  <section class="investor-pipeline">
    <header><p>Project pipeline</p><h2>Three public development regions.</h2><p>Public project surfaces offer the clearest current view. Detailed economics and timing belong in the investor briefing.</p></header>
    <ol>{PROJECTS.map((project, index) => <li><span>0{index + 1}</span><div><h3>{project.place}</h3><p>{project.region} / {project.corridor}</p></div><p>{project.activity}</p><a href={project.href} target="_blank" rel="noopener noreferrer">Public source ↗</a></li>)}</ol>
  </section>

  <section class="investor-recognition">
    <p>Recognition</p>
    <h2>Visible in the next generation of charging operators.</h2>
    <p>Rangeway was named among the next generation of charge point operators in Ohm Analytics' Q3 2025 US EV Charging Market Report and is a quarter-finalist in the Pepperdine Most Fundable Companies program.</p>
    <div class="button-row"><a class="text-link" href="https://hs-21752392.f.hubspotstarter.net/hubfs/21752392/OhmAnalytics_EVCharging_2025Q3Report_20251211_Sample.pdf" target="_blank" rel="noopener noreferrer">Ohm Analytics report <span>↗</span></a><a class="text-link" href="https://bschool.pepperdine.edu/events/most-fundable-companies/" target="_blank" rel="noopener noreferrer">Pepperdine program <span>↗</span></a></div>
  </section>

  <section class="investor-action"><div><p>Investor materials</p><h2>Request the investor briefing.</h2></div><div><p>The briefing includes the market thesis, corridor strategy, format economics, partner roster, and capital plan for serious partners.</p><a class="button button--sun" href="mailto:investors@rangeway.co?subject=Investor%20Briefing%20Request">investors@rangeway.co</a></div></section>
</SiteLayout>

<style>
  .investor-proof-opening { padding: 205px var(--page-pad) 0; background: var(--cream); }
  .investor-proof-opening__thesis { max-width: 980px; }
  .investor-proof-opening h1 { max-width: 11ch; margin: 0 0 34px; font-size: clamp(4.4rem,8.4vw,8.8rem); }
  .investor-proof-opening__thesis > p:not(.eyebrow) { max-width: 50ch; color: var(--slate); font-size: 1.15rem; }
  .investor-proof-opening__thesis .button:not(.button--sun) { border-color: var(--navy); }
  .investor-evidence-rail { display: grid; grid-template-columns: repeat(3,1fr); margin: 76px 0 0; border-top: 2px solid var(--navy); }
  .investor-evidence-rail > div { min-height: 190px; padding: 24px 26px 28px 0; border-right: 1px solid rgba(20,43,53,.3); }
  .investor-evidence-rail dt { margin-bottom: 38px; color: var(--oxide); font: 600 .64rem var(--font-mono); text-transform: uppercase; }
  .investor-evidence-rail dd { display: flex; align-items: baseline; gap: 14px; margin: 0; }
  .investor-evidence-rail strong { font: 700 clamp(2rem,4vw,4rem)/1 var(--font-display); }
  .investor-evidence-rail span { max-width: 170px; font: 600 .64rem/1.35 var(--font-mono); text-transform: uppercase; }
  .investor-thesis { display: grid; grid-template-columns: .72fr 1.28fr; gap: 70px; padding: var(--section-pad) var(--page-pad); background: var(--cream); }
  .investor-thesis header > p, .investor-evidence__title > p, .investor-pipeline header > p:first-child, .investor-recognition > p:first-child, .investor-action > div:first-child > p { color: var(--oxide); font: 600 .66rem var(--font-mono); letter-spacing: .1em; text-transform: uppercase; }
  .investor-thesis h2, .investor-evidence h2, .investor-pipeline h2, .investor-recognition h2, .investor-action h2 { font-size: clamp(3.2rem,6vw,6.3rem); }
  .investor-thesis > div { display: grid; grid-template-columns: repeat(2,1fr); }
  .investor-thesis article { min-height: 290px; padding: 28px; border: 1px solid rgba(20,43,53,.25); margin: -1px 0 0 -1px; }
  .investor-thesis article span { color: var(--oxide); font: 500 .66rem var(--font-mono); }
  .investor-thesis article h3 { margin: 76px 0 14px; font-size: 1.55rem; }
  .investor-thesis article p { color: var(--slate); font-size: .92rem; }
  .investor-evidence { display: grid; grid-template-columns: .8fr 1.2fr; gap: 70px; padding: var(--section-pad) var(--page-pad); background: var(--sun); }
  .investor-evidence__facts > p { max-width: 48ch; font-size: 1.2rem; }
  .investor-evidence__facts > div { display: grid; grid-template-columns: repeat(3,1fr); margin-top: 60px; border-top: 2px solid var(--navy); }
  .investor-evidence article { padding: 22px 16px 0 0; }
  .investor-evidence article strong, .investor-evidence article span { display: block; }
  .investor-evidence article strong { font: 700 1.2rem var(--font-display); }
  .investor-evidence article span, .investor-evidence article p { font: 500 .65rem var(--font-mono); text-transform: uppercase; }
  .investor-pipeline { padding: var(--section-pad) var(--page-pad); background: var(--warm-white); }
  .investor-pipeline header { display: grid; grid-template-columns: .35fr 1fr .55fr; gap: 34px; align-items: end; margin-bottom: 64px; }
  .investor-pipeline h2 { margin: 0; }
  .investor-pipeline header > p:last-child { color: var(--slate); }
  .investor-pipeline ol { margin: 0; padding: 0; list-style: none; border-top: 2px solid var(--navy); }
  .investor-pipeline li { display: grid; grid-template-columns: 44px .75fr 1.25fr 100px; gap: 24px; align-items: center; min-height: 132px; border-bottom: 1px solid rgba(20,43,53,.3); }
  .investor-pipeline li > span, .investor-pipeline li > a, .investor-pipeline li div p { font: 500 .64rem var(--font-mono); color: var(--oxide); text-transform: uppercase; }
  .investor-pipeline li h3 { margin: 0; font-size: 2rem; }
  .investor-pipeline li p { margin: 0; }
  .investor-recognition { display: grid; grid-template-columns: .35fr 1fr .6fr; gap: 40px; align-items: start; padding: var(--section-pad) var(--page-pad); background: var(--navy); color: white; }
  .investor-recognition h2 { margin: 0; }
  .investor-recognition > p:nth-of-type(2) { color: rgba(255,255,255,.7); }
  .investor-recognition .button-row { grid-column: 2/4; margin-top: 30px; }
  .investor-action { display: grid; grid-template-columns: 1.2fr .8fr; gap: 60px; align-items: end; padding: var(--section-pad) var(--page-pad); background: var(--oxide); color: white; }
  .investor-action h2 { margin-bottom: 0; }
  .investor-action > div:last-child > p { color: rgba(255,255,255,.75); }
  @media (max-width: 820px) {
    .investor-thesis, .investor-evidence, .investor-recognition, .investor-action { grid-template-columns: 1fr; }
    .investor-proof-opening { padding: 150px 20px 0; }
    .investor-evidence-rail { grid-template-columns: 1fr; margin-top: 48px; }
    .investor-evidence-rail > div { min-height: 130px; }
    .investor-thesis, .investor-evidence, .investor-pipeline, .investor-recognition, .investor-action { padding-inline: 20px; }
    .investor-thesis > div { grid-template-columns: 1fr; }
    .investor-pipeline header { grid-template-columns: 1fr; }
    .investor-pipeline li { grid-template-columns: 32px 1fr auto; padding: 24px 0; }
    .investor-pipeline li > p { grid-column: 2/4; }
    .investor-recognition .button-row { grid-column: auto; }
  }
</style>
