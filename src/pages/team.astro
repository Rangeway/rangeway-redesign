---
import SiteLayout from "../layouts/SiteLayout.astro";
import PeopleField from "../components/PeopleField.astro";
import { EXTERNAL_LINKS } from "../data/site-content";
---

<SiteLayout title="Team · Rangeway" description="The hospitality, design, growth, and policy leaders building Rangeway." class="team-family">
  <section class="team-intro">
    <p class="eyebrow">Leadership / Rangeway</p>
    <h1>The people doing the work.</h1>
    <p>Every Rangeway decision is made by people who understand guest experience, infrastructure, the EV market, or the road itself.</p>
  </section>
  <section class="team-people" aria-label="Rangeway team"><PeopleField /></section>
  <section class="team-careers">
    <div><p class="eyebrow eyebrow--sun">Join us</p><h2>Build the stop you wish existed.</h2></div>
    <div><p>We are looking for hospitality operators, site leads, energy engineers, and people who care how a good stop feels.</p><div class="button-row"><a class="button button--sun" href="mailto:careers@rangeway.co?subject=Joining%20Rangeway">Email careers</a><a class="button button--outline-light" href={EXTERNAL_LINKS.careers} target="_blank" rel="noopener noreferrer">View LinkedIn jobs</a></div></div>
  </section>
</SiteLayout>

<style>
  .team-intro { display: grid; grid-template-columns: .4fr 1.15fr .55fr; gap: 34px; align-items: end; min-height: 650px; padding: 180px var(--page-pad) 78px; background: var(--sun); }
  .team-intro h1 { margin: 0; font-size: clamp(4.6rem,9vw,9.5rem); }
  .team-intro > p:last-child { max-width: 40ch; margin-bottom: 8px; }
  .team-people { padding: var(--section-pad) var(--page-pad) calc(var(--section-pad) + 110px); background: var(--warm-white); }
  .team-careers { display: grid; grid-template-columns: 1.25fr .75fr; gap: 80px; align-items: end; padding: var(--section-pad) var(--page-pad); background: var(--navy-deep); color: white; }
  .team-careers h2 { max-width: 11ch; font-size: clamp(3.6rem,7vw,7.4rem); }
  .team-careers > div:last-child > p { max-width: 42ch; color: rgba(255,255,255,.7); }
  @media (max-width: 820px) { .team-intro, .team-careers { grid-template-columns: 1fr; padding-inline: 20px; } .team-intro { min-height: 620px; padding-top: 140px; } .team-people { padding-inline: 20px; padding-bottom: 80px; } }
</style>
