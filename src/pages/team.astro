---
import SiteLayout from "../layouts/SiteLayout.astro";
import PeopleField from "../components/PeopleField.astro";
import { EXTERNAL_LINKS } from "../data/site-content";
---

<SiteLayout title="Team · Rangeway" description="The hospitality, design, growth, finance, and policy leaders building Rangeway." class="team-family">
  <section class="team-people-opening" aria-label="Rangeway team">
    <header><p class="eyebrow">Leadership / Rangeway</p><h1>The people doing the work.</h1><p>Hospitality, infrastructure, finance, the EV market, and the road itself—all visible in one working team.</p></header>
    <PeopleField />
  </section>
  <section class="team-careers">
    <div><p class="eyebrow eyebrow--sun">Join us</p><h2>Build the stop you wish existed.</h2></div>
    <div><p>We are looking for hospitality operators, site leads, energy engineers, and people who care how a good stop feels.</p><div class="button-row"><a class="button button--sun" href="mailto:careers@rangeway.co?subject=Joining%20Rangeway">Email careers</a><a class="button button--outline-light" href={EXTERNAL_LINKS.careers} target="_blank" rel="noopener noreferrer">View LinkedIn jobs</a></div></div>
  </section>
</SiteLayout>

<style>
  .team-people-opening { padding: 170px var(--page-pad) calc(var(--section-pad) + 110px); background: var(--warm-white); }
  .team-people-opening > header { display: flex; flex-wrap: wrap; align-items: end; gap: 24px clamp(34px,6vw,100px); margin-bottom: 64px; padding-bottom: 36px; border-bottom: 2px solid var(--navy); }
  .team-people-opening h1 { flex: 1 1 620px; margin: 0; font-size: clamp(3.8rem,7vw,7.6rem); }
  .team-people-opening header > p:first-child { width: 100%; }
  .team-people-opening header > p:last-child { flex: 0 1 350px; margin-bottom: 8px; color: var(--slate); }
  .team-careers { display: grid; grid-template-columns: 1.25fr .75fr; gap: 80px; align-items: end; padding: var(--section-pad) var(--page-pad); background: var(--navy-deep); color: white; }
  .team-careers h2 { max-width: 11ch; font-size: clamp(3.6rem,7vw,7.4rem); }
  .team-careers > div:last-child > p { max-width: 42ch; color: rgba(255,255,255,.7); }
  @media (max-width: 820px) { .team-careers { grid-template-columns: 1fr; } .team-people-opening { padding: 130px 20px 80px; } .team-people-opening > header { margin-bottom: 38px; } .team-careers { padding-inline: 20px; } }
</style>
