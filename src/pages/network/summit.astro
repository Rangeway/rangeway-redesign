---
// HERO: A wide horizon and measured destination ledger slow the page to Summit's overnight pace.
import OperatingFacts from "../../components/OperatingFacts.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { FORMATS } from "../../data/site-content";

const format = FORMATS[2];
const facts = [
  { label: "Operating model", value: "Destination experience", detail: "A slower format organized around place." },
  { label: "Hospitality", value: "Lookouts", detail: "Site-specific overnight spaces with a central clubhouse." },
  { label: "Energy concept", value: "Off-grid", detail: "Solar and battery systems are central to the format concept." },
] as const;
---

<SiteLayout
  title="Summit · Rangeway"
  description="Summit is Rangeway’s destination format, designed around Lookouts, a central clubhouse, and off-grid solar and battery systems."
  class="summit-page"
>
  <article data-composition="summit-destination">
    <section class="summit-horizon" aria-labelledby="summit-title">
      <ResponsiveImage
        src={format.image}
        srcSmall={format.imageSmall}
        alt="Concept rendering of a Rangeway Summit clubhouse and solar charging canopy in a desert mountain landscape"
        width={2200}
        height={1200}
        sizes="100vw"
        class="summit-horizon__image"
        position="center 55%"
        loading="eager"
      />
      <p class="concept-label concept-label--hero">Concept rendering</p>
      <div class="summit-horizon__veil"></div>
      <div class="summit-horizon__copy">
        <p class="eyebrow eyebrow--sun">Format 03 · {format.context}</p>
        <h1 id="summit-title">Summit</h1>
        <p>A destination-scale Rangeway experience shaped by the landscape, a central clubhouse, and site-specific Lookouts.</p>
      </div>
      <p class="summit-horizon__pace">Slow the stop. Keep the journey.</p>
    </section>

    <section class="summit-thesis" aria-labelledby="summit-thesis-title">
      <p class="eyebrow">Destination pace</p>
      <h2 id="summit-thesis-title">Some journeys need more than a pause.</h2>
      <div>
        <p>
          Summit expands Rangeway from a charging stop into a place to settle for the night. The
          model pairs site-specific Lookouts with shared hospitality at a central clubhouse.
        </p>
        <p>
          The energy concept is equally place-driven: off-grid solar and battery systems designed
          around remote travel and each site’s specific conditions.
        </p>
      </div>
    </section>

    <OperatingFacts facts={facts} label="Summit operating facts" tone="light" />

    <section class="destination-ledger" aria-labelledby="ledger-title">
      <header>
        <p class="eyebrow eyebrow--sun">A shared center · a private horizon</p>
        <h2 id="ledger-title">The destination is organized in layers.</h2>
      </header>
      <div class="destination-ledger__entries">
        <article>
          <p>01 · Arrival</p>
          <h3>Clubhouse</h3>
          <p>The social and service center of the format: a shared point of arrival, gathering, and reset.</p>
        </article>
        <article>
          <p>02 · Overnight</p>
          <h3>Lookouts</h3>
          <p>Site-specific places to stay, named for their relationship to the landscape and the view beyond the stop.</p>
        </article>
        <article>
          <p>03 · Power</p>
          <h3>Solar + battery</h3>
          <p>An off-grid energy concept that treats the site and its power architecture as one system.</p>
        </article>
      </div>
    </section>

    <section class="summit-energy" aria-labelledby="summit-energy-title">
      <ResponsiveImage
        src="/images/summit-solar-aerial.webp"
        srcSmall="/images/summit-solar-aerial-640.webp"
        alt="Concept rendering of a Rangeway Summit clubhouse, Lookouts, charging canopy, and solar arrays in a desert landscape"
        width={2200}
        height={1200}
        sizes="(max-width: 820px) 100vw, 66vw"
        class="summit-energy__image"
        position="center 50%"
      />
      <p class="concept-label">Concept rendering</p>
      <div class="summit-energy__copy">
        <p class="eyebrow">Energy as place-making</p>
        <h2 id="summit-energy-title">Off-grid by concept. Site-specific by design.</h2>
        <p>
          Solar generation and battery storage are integral to the Summit model. Final systems and
          visitor services depend on the verified design of each public project.
        </p>
      </div>
    </section>

    <section class="summit-return" aria-labelledby="summit-return-title">
      <div>
        <p class="eyebrow eyebrow--sun">Return to the network</p>
        <h2 id="summit-return-title">Three formats. One indoor-comfort standard.</h2>
      </div>
      <div>
        <p>Compare Waystation, Basecamp, and Summit without mistaking a design model for current operating status.</p>
        <a class="button button--sun" href="/network">Compare the formats</a>
      </div>
    </section>
  </article>
</SiteLayout>

<style>
  .summit-horizon { position: relative; min-height: 1040px; padding-top: 120px; background: var(--navy-deep); color: white; }
  .summit-horizon__image, .summit-horizon__veil { position: absolute; inset: 0; }
  .summit-horizon__veil { background: linear-gradient(180deg, rgba(20, 43, 53, .18), rgba(20, 43, 53, .08) 48%, rgba(20, 43, 53, .86)); }
  .summit-horizon__copy { position: absolute; z-index: 1; left: var(--page-pad); bottom: clamp(70px, 9vw, 140px); max-width: 1000px; }
  .summit-horizon h1 { margin: 0; font-size: clamp(6rem, 17vw, 17rem); line-height: .72; letter-spacing: -.075em; }
  .summit-horizon__copy > p:last-child { max-width: 52ch; margin: 40px 0 0 auto; color: rgba(255, 255, 255, .8); font-size: 1.1rem; }
  .summit-horizon__pace { position: absolute; z-index: 1; right: var(--page-pad); top: 170px; margin: 0; writing-mode: vertical-rl; font: 500 .63rem var(--font-mono); letter-spacing: .12em; text-transform: uppercase; }

  .summit-thesis { display: grid; grid-template-columns: .35fr 1fr .65fr; gap: 38px; padding: var(--section-pad) var(--page-pad); background: var(--cream); }
  .summit-thesis h2 { max-width: 10ch; margin: 0; font-size: clamp(4rem, 8vw, 8.3rem); }
  .summit-thesis > div { align-self: end; }
  .summit-thesis > div p { max-width: 43ch; }
  .summit-thesis > div p:last-child { color: var(--slate); }
  :global(.summit-page .operating-facts) { --fact-count: 3; margin: 0 var(--page-pad); }

  .destination-ledger { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(50px, 9vw, 150px); padding: var(--section-pad) var(--page-pad); background: var(--warm-white); }
  .destination-ledger header { align-self: start; }
  .destination-ledger h2 { max-width: 10ch; margin: 0; font-size: clamp(3.5rem, 6.5vw, 6.8rem); }
  .destination-ledger__entries article { padding: 32px 0 58px; border-top: 1px solid rgba(20, 43, 53, .3); }
  .destination-ledger__entries article:last-child { border-bottom: 1px solid rgba(20, 43, 53, .3); }
  .destination-ledger__entries article > p:first-child { font: 500 .64rem var(--font-mono); letter-spacing: .09em; text-transform: uppercase; color: var(--oxide); }
  .destination-ledger h3 { margin: 45px 0 20px; font-size: clamp(2.7rem, 5vw, 5.2rem); }
  .destination-ledger__entries article > p:last-child { max-width: 48ch; color: var(--slate); }

  .summit-energy { position: relative; display: grid; grid-template-columns: 1.35fr .65fr; min-height: 810px; background: var(--navy); color: white; }
  .summit-energy__image { min-height: 810px; }
  .summit-energy__copy { align-self: center; padding: clamp(54px, 7vw, 112px); }
  .summit-energy h2 { margin-bottom: 28px; font-size: clamp(3.1rem, 5.4vw, 5.8rem); }
  .summit-energy__copy > p:not(.eyebrow) { color: rgba(255, 255, 255, .7); }

  .summit-return { display: grid; grid-template-columns: 1.15fr .85fr; gap: 60px; align-items: end; padding: var(--section-pad) var(--page-pad); background: var(--oxide); color: white; }
  .summit-return h2 { max-width: 12ch; margin: 0; font-size: clamp(3.8rem, 7vw, 7.4rem); }
  .summit-return > div:last-child > p { max-width: 42ch; margin-bottom: 34px; color: rgba(255, 255, 255, .78); }

  @media (prefers-reduced-motion: no-preference) {
    .summit-horizon__image { animation: summit-mask 1.1s var(--ease-out) both; }
    @keyframes summit-mask { from { clip-path: inset(0 0 18%); } to { clip-path: inset(0); } }
  }

  @media (max-width: 820px) {
    .summit-horizon { min-height: 860px; }
    .summit-horizon__copy { left: 20px; right: 20px; }
    .summit-horizon h1 { font-size: clamp(5.5rem, 28vw, 8.2rem); }
    .summit-horizon__copy > p:last-child { margin-left: 0; }
    .summit-horizon__pace { right: 20px; top: 135px; }
    .summit-thesis, .destination-ledger, .summit-energy, .summit-return { grid-template-columns: 1fr; }
    .summit-thesis, .destination-ledger, .summit-return { padding-inline: 20px; }
    :global(.summit-page .operating-facts) { margin: 0 20px; }
    .summit-energy__image { min-height: 520px; }
    .summit-energy__copy { padding: 74px 20px; }
  }
</style>
