---
// HERO: A continuous route trace carries the traveler through a compact automated stop in four beats.
import OperatingFacts from "../../components/OperatingFacts.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { FORMATS } from "../../data/site-content";

const format = FORMATS[0];
const facts = [
  { label: "Operating model", value: "Automated + unstaffed", detail: "Designed for a clear, self-directed visit." },
  { label: "Primary rhythm", value: "Regional reset", detail: "A compact pause before returning to the route." },
  { label: "Comfort baseline", value: "Indoors", detail: "Climate control, restrooms, seating, and Wi-Fi." },
] as const;
---

<SiteLayout
  title="Waystation · Rangeway"
  description="Waystation is Rangeway’s automated, unstaffed format for a reliable indoor reset on regional routes."
  class="waystation-page"
>
  <article data-composition="waystation-flow">
    <section class="waystation-lead" aria-labelledby="waystation-title">
      <div class="waystation-lead__route" aria-hidden="true"><i></i><span>Regional route / reset / return</span></div>
      <div class="waystation-lead__copy">
        <p class="eyebrow eyebrow--sun">Format 01 · {format.context}</p>
        <h1 id="waystation-title">Waystation</h1>
        <p>
          A compact, automated, and unstaffed Rangeway stop designed to make the essential charging
          pause feel dependable, warm, and easy to navigate.
        </p>
      </div>
      <ResponsiveImage
        src={format.image}
        srcSmall={format.imageSmall}
        alt="A compact Rangeway Waystation set among Joshua trees at dusk"
        width={768}
        height={810}
        sizes="(max-width: 820px) 100vw, 46vw"
        class="waystation-lead__image"
        position="center 54%"
        loading="eager"
      />
    </section>

    <OperatingFacts facts={facts} label="Waystation operating facts" tone="sun" />

    <section class="route-flow" aria-labelledby="route-flow-title">
      <header>
        <p class="eyebrow">A self-directed stop</p>
        <h2 id="route-flow-title">Four moves.<br />No service theater.</h2>
        <p>
          The model is designed to make the path from arrival to departure legible without relying
          on an on-site team.
        </p>
      </header>
      <ol>
        <li><span>01</span><strong>Arrive</strong><p>A compact footprint keeps the transition off the route straightforward.</p></li>
        <li><span>02</span><strong>Charge</strong><p>The charging session anchors the visit; equipment details remain project-specific.</p></li>
        <li><span>03</span><strong>Reset indoors</strong><p>Climate control, clean restrooms, seating, Wi-Fi, and local provisions support the pause.</p></li>
        <li><span>04</span><strong>Return</strong><p>The visit ends with a simple move back to the road.</p></li>
      </ol>
    </section>

    <section class="waystation-essentials" aria-labelledby="essentials-title">
      <div class="waystation-essentials__signal">
        <div class="waystation-essentials__route" aria-hidden="true"><i></i><i></i><i></i></div>
        <p><span>Indoor comfort</span><strong>Every format</strong></p>
      </div>
      <div class="waystation-essentials__copy">
        <p class="eyebrow eyebrow--sun">Essential hospitality</p>
        <h2 id="essentials-title">The baseline is a better place to wait.</h2>
        <p>
          Waystation compresses Rangeway’s indoor-comfort standard into the smallest format. It is
          not a staffed cafe or destination stay; it is the practical reset many routes are missing.
        </p>
        <ul>
          <li>Climate-controlled interior</li>
          <li>Clean restrooms</li>
          <li>Seating and Wi-Fi</li>
          <li>Local provisions</li>
        </ul>
      </div>
    </section>

    <section class="waystation-next" aria-labelledby="waystation-next-title">
      <div>
        <p class="eyebrow">Need a fuller service model?</p>
        <h2 id="waystation-next-title">Continue to Basecamp.</h2>
      </div>
      <div>
        <p>Basecamp expands the stop with staffed hospitality, Trailkeepers, and cafe service.</p>
        <a class="button button--sun" href="/network/basecamp">Explore Basecamp</a>
      </div>
    </section>
  </article>
</SiteLayout>

<style>
  .waystation-lead {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, .92fr);
    min-height: 850px;
    padding-top: 126px;
    background: var(--navy-deep);
    color: white;
  }

  .waystation-lead__copy { min-width: 0; align-self: end; padding: 90px var(--page-pad); }
  .waystation-lead h1 {
    max-width: 100%;
    margin: 0 0 35px;
    font-size: clamp(3.8rem, 7.4vw, 7rem);
    line-height: .82;
    letter-spacing: -.075em;
    white-space: nowrap;
  }
  .waystation-lead__copy > p:last-child { max-width: 44ch; color: rgba(255, 255, 255, .76); font-size: 1.1rem; }
  .waystation-lead__image { min-height: 724px; }
  .waystation-lead__route { position: absolute; z-index: 2; top: 166px; left: var(--page-pad); right: var(--page-pad); display: flex; align-items: center; gap: 18px; }
  .waystation-lead__route i { position: relative; display: block; width: min(50vw, 680px); height: 2px; background: var(--sun); }
  .waystation-lead__route i::after { content: ""; position: absolute; right: 0; top: -6px; width: 14px; height: 14px; border: 2px solid var(--sun); border-radius: 50%; background: var(--navy-deep); }
  .waystation-lead__route span { font: 500 .61rem var(--font-mono); letter-spacing: .09em; text-transform: uppercase; color: rgba(255, 255, 255, .6); }

  :global(.waystation-page .operating-facts) { --fact-count: 3; }
  .route-flow { padding: var(--section-pad) var(--page-pad); background: var(--warm-white); }
  .route-flow > header { display: grid; grid-template-columns: .5fr 1fr .5fr; gap: 34px; align-items: end; margin-bottom: clamp(70px, 9vw, 132px); }
  .route-flow h2 { margin: 0; font-size: clamp(3.8rem, 7.5vw, 7.7rem); }
  .route-flow header > p:last-child { max-width: 38ch; margin: 0 0 8px; color: var(--slate); }
  .route-flow ol { position: relative; display: grid; grid-template-columns: repeat(4, 1fr); margin: 0; padding: 0; list-style: none; }
  .route-flow ol::before { content: ""; position: absolute; top: 18px; left: 5%; right: 5%; height: 2px; background: var(--oxide); }
  .route-flow li { position: relative; padding: 0 clamp(16px, 3vw, 42px) 0 0; }
  .route-flow li::before { content: ""; position: relative; z-index: 1; display: block; width: 36px; height: 36px; margin-bottom: 64px; border: 9px solid var(--warm-white); outline: 2px solid var(--oxide); border-radius: 50%; background: var(--oxide); }
  .route-flow li span { font: 500 .64rem var(--font-mono); color: var(--oxide); }
  .route-flow li strong { display: block; margin: 10px 0 18px; font: 700 clamp(1.4rem, 2.4vw, 2.45rem) var(--font-display); }
  .route-flow li p { max-width: 30ch; margin: 0; color: var(--slate); font-size: .92rem; }

  .waystation-essentials { display: grid; grid-template-columns: minmax(280px, .8fr) minmax(360px, 1.2fr); min-height: 720px; background: var(--navy); color: white; }
  .waystation-essentials__signal { position: relative; display: grid; min-width: 0; place-items: center; padding: 48px; border-right: 1px solid rgba(255, 255, 255, .2); overflow: clip; }
  .waystation-essentials__signal::before,
  .waystation-essentials__signal::after { content: ""; position: absolute; border: 2px solid rgba(242, 182, 76, .35); border-radius: 50%; }
  .waystation-essentials__signal::before { width: min(38vw, 500px); aspect-ratio: 1; }
  .waystation-essentials__signal::after { width: min(25vw, 320px); aspect-ratio: 1; }
  .waystation-essentials__route { position: relative; z-index: 1; display: flex; width: min(26vw, 340px); align-items: center; }
  .waystation-essentials__route::before { content: ""; width: 100%; height: 3px; background: var(--sun); }
  .waystation-essentials__route i { position: absolute; width: 19px; height: 19px; border: 5px solid var(--navy); outline: 2px solid var(--sun); border-radius: 50%; background: var(--sun); }
  .waystation-essentials__route i:first-child { left: 0; }
  .waystation-essentials__route i:nth-child(2) { left: 50%; transform: translateX(-50%); }
  .waystation-essentials__route i:last-child { right: 0; }
  .waystation-essentials__signal > p { position: absolute; z-index: 2; left: 48px; right: 48px; bottom: 48px; display: flex; justify-content: space-between; gap: 20px; margin: 0; padding-top: 16px; border-top: 1px solid rgba(255, 255, 255, .35); }
  .waystation-essentials__signal span { font: 500 .63rem var(--font-mono); letter-spacing: .1em; text-transform: uppercase; color: var(--sun); }
  .waystation-essentials__signal strong { font: 700 .76rem var(--font-display); text-transform: uppercase; }
  .waystation-essentials__copy { align-self: center; padding: clamp(60px, 8vw, 130px); }
  .waystation-essentials h2 { max-width: 10ch; margin-bottom: 28px; font-size: clamp(3.2rem, 6vw, 6.5rem); }
  .waystation-essentials__copy > p:not(.eyebrow) { max-width: 45ch; color: rgba(255, 255, 255, .7); }
  .waystation-essentials ul { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; margin: 44px 0 0; padding: 0; list-style: none; border-top: 1px solid rgba(255, 255, 255, .24); border-left: 1px solid rgba(255, 255, 255, .24); }
  .waystation-essentials li { padding: 18px; border-right: 1px solid rgba(255, 255, 255, .24); border-bottom: 1px solid rgba(255, 255, 255, .24); font: 600 .72rem var(--font-mono); letter-spacing: .05em; text-transform: uppercase; }

  .waystation-next { display: grid; grid-template-columns: 1.1fr .9fr; gap: 60px; align-items: end; padding: var(--section-pad) var(--page-pad); background: var(--cream); }
  .waystation-next h2 { margin: 0; font-size: clamp(3.6rem, 7.5vw, 7.7rem); }
  .waystation-next > div:last-child > p { max-width: 42ch; margin-bottom: 32px; color: var(--slate); }

  @media (prefers-reduced-motion: no-preference) {
    .waystation-lead__route i { animation: waystation-route 1.1s var(--ease-out) both; transform-origin: left; }
    @keyframes waystation-route { from { transform: scaleX(0); } to { transform: scaleX(1); } }
  }

  @media (max-width: 820px) {
    .waystation-lead { grid-template-columns: 1fr; padding-top: 100px; }
    .waystation-lead__copy { padding: 130px 20px 55px; }
    .waystation-lead h1 { font-size: clamp(3rem, 15.5vw, 4rem); }
    .waystation-lead__image { min-height: 520px; }
    .waystation-lead__route { top: 132px; left: 20px; right: 20px; }
    .waystation-lead__route span { display: none; }
    .route-flow { padding-inline: 20px; }
    .route-flow > header { grid-template-columns: 1fr; }
    .route-flow ol { grid-template-columns: 1fr; }
    .route-flow ol::before { top: 0; bottom: 0; left: 17px; right: auto; width: 2px; height: auto; }
    .route-flow li { display: grid; grid-template-columns: 44px 1fr; padding: 0 0 42px; }
    .route-flow li::before { grid-row: 1 / 4; margin: 0; }
    .route-flow li span, .route-flow li strong, .route-flow li p { grid-column: 2; }
    .waystation-essentials { grid-template-columns: 1fr; min-height: 0; }
    .waystation-essentials__signal { min-height: 360px; border-right: 0; border-bottom: 1px solid rgba(255, 255, 255, .2); }
    .waystation-essentials__signal::before { width: min(108vw, 430px); }
    .waystation-essentials__signal::after { width: min(70vw, 280px); }
    .waystation-essentials__route { width: min(70vw, 280px); }
    .waystation-essentials__signal > p { left: 20px; right: 20px; bottom: 24px; }
    .waystation-essentials__copy { padding: 72px 20px; }
    .waystation-next { grid-template-columns: 1fr; padding-inline: 20px; }
  }
</style>
