---
import SiteLayout from "../layouts/SiteLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { EXTERNAL_LINKS, SITE } from "../data/site-content";

const routes = [
  ["General", "hello@rangeway.co", "Questions about Rangeway, the network, or a public project."],
  ["Press and media", "media@rangeway.co", "Time-sensitive media inquiries, interviews, and company materials."],
  ["Careers", "careers@rangeway.co", "Introductions and roles not already listed on LinkedIn."],
  ["Investors", "investors@rangeway.co", "Briefing requests, diligence, and investor materials."],
  ["Partnerships", "partners@rangeway.co", "Technology, energy, infrastructure, and service collaborations."],
];
---

<SiteLayout title="Contact · Rangeway" description="Reach Rangeway about the network, partnerships, investors, careers, or media." class="contact-family">
  <section class="contact-support-opening">
    <header><div><p class="eyebrow">Contact / Start here</p><h1>A real reply.</h1></div><p>Choose a direct desk or send one note through the inquiry form. Expect a reply within two business days; investor and partnership notes may move faster.</p></header>
    <div class="contact-support-opening__workbench">
      <nav aria-label="Direct contact routes"><p>Send it to the right desk.</p>{routes.map(([label, email, description]) => <a href={`mailto:${email}`}><span>{label}</span><strong>{email}</strong><small>{description}</small><i aria-hidden="true">↗</i></a>)}</nav>
      <div class="contact-support-opening__form"><p class="eyebrow">Inquiry form</p><h2>Tell us what brings you here.</h2><ContactForm /></div>
    </div>
  </section>
  <section class="contact-details">
    <div><p>Call</p><a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></div>
    <div><p>Write</p><address>{SITE.legalName}<br />2661 Market Street, STE 85787<br />San Francisco, CA 94114</address></div>
    <div><p>Current materials</p><a href={EXTERNAL_LINKS.newsroom} target="_blank" rel="noopener noreferrer">Newsroom ↗</a><a href={EXTERNAL_LINKS.careers} target="_blank" rel="noopener noreferrer">LinkedIn jobs ↗</a><a href={EXTERNAL_LINKS.investorHub} target="_blank" rel="noopener noreferrer">Investor Hub ↗</a></div>
  </section>
</SiteLayout>

<style>
  .contact-support-opening { padding: 160px var(--page-pad) 90px; background: var(--cream); }
  .contact-support-opening > header { display: flex; align-items: end; justify-content: space-between; gap: 50px; margin-bottom: 44px; padding-bottom: 30px; border-bottom: 2px solid var(--navy); }
  .contact-support-opening h1 { margin: 0; font-size: clamp(3.8rem,7vw,7.4rem); }
  .contact-support-opening > header > p { max-width: 47ch; margin-bottom: 8px; color: var(--slate); }
  .contact-support-opening__workbench { display: grid; grid-template-columns: minmax(320px,.75fr) minmax(430px,1.25fr); gap: clamp(44px,8vw,120px); align-items: start; }
  .contact-support-opening nav { border-top: 1px solid rgba(20,43,53,.35); }
  .contact-support-opening nav > p { padding: 18px 0; border-bottom: 1px solid rgba(20,43,53,.3); color: var(--oxide); font: 600 .67rem var(--font-mono); text-transform: uppercase; }
  .contact-support-opening nav a { display: grid; grid-template-columns: 1fr auto; gap: 4px 14px; padding: 15px 0; border-bottom: 1px solid rgba(20,43,53,.3); }
  .contact-support-opening nav a span { color: var(--oxide); font: 600 .61rem var(--font-mono); text-transform: uppercase; }
  .contact-support-opening nav a strong { grid-column: 1; font: 700 1rem var(--font-display); }
  .contact-support-opening nav a small { grid-column: 1; color: var(--slate); font-size: .78rem; }
  .contact-support-opening nav a i { grid-column: 2; grid-row: 1/4; align-self: center; font-style: normal; }
  .contact-support-opening__form { padding: 30px; background: var(--warm-white); box-shadow: 16px 16px 0 var(--sun); }
  .contact-support-opening__form h2 { margin-bottom: 34px; font-size: clamp(2.5rem,4vw,4.4rem); }
  .contact-details { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; padding: 1px; background: var(--navy-deep); color: white; }
  .contact-details > div { display: flex; min-height: 220px; flex-direction: column; gap: 8px; padding: 34px var(--page-pad); background: var(--navy); }
  .contact-details p { color: var(--sun); font: 600 .65rem var(--font-mono); text-transform: uppercase; }
  .contact-details address { font-style: normal; }
  @media (max-width: 820px) { .contact-support-opening { padding: 130px 20px 70px; } .contact-support-opening > header { display: block; } .contact-support-opening__workbench, .contact-details { grid-template-columns: 1fr; } .contact-support-opening__form { padding: 24px; box-shadow: 10px 10px 0 var(--sun); } }
</style>
