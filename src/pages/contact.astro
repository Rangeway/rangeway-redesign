---
import SiteLayout from "../layouts/SiteLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { EXTERNAL_LINKS, SITE } from "../data/site-content";

const routes = [
  ["General", "hello@rangeway.co", "Questions about Rangeway, the network, or a public project."],
  ["Press and media", "media@rangeway.co", "Time-sensitive media inquiries, interviews, and company materials."],
  ["Careers", "careers@rangeway.co", "Introductions and roles not already listed on LinkedIn."],
  ["Investors", "investors@rangeway.co", "Briefing requests, diligence, and investor materials."],
  ["Partnerships", "partners@rangeway.co", "Technology, energy, infrastructure, and service collaborations."],
];
---

<SiteLayout title="Contact · Rangeway" description="Reach Rangeway about the network, partnerships, investors, careers, or media." class="contact-family">
  <section class="contact-opening"><p class="eyebrow">Contact / Start here</p><h1>A real reply.</h1><div><p>Questions about the network, partnerships, investors, or joining the team. Every note is read by a person.</p><p>Expect a reply within two business days. Investor and partnership notes may move faster.</p></div></section>
  <section class="contact-routes" aria-label="Direct contact routes"><header><p>Direct routes</p><h2>Send it to the right desk.</h2></header><div>{routes.map(([label, email, description]) => <a href={`mailto:${email}`}><span>{label}</span><strong>{email}</strong><p>{description}</p><i aria-hidden="true">↗</i></a>)}</div></section>
  <section class="contact-conversation">
    <div class="contact-conversation__form"><p class="eyebrow">Inquiry form</p><h2>Tell us what brings you here.</h2><p>Select the closest route and add context. The form posts natively through Formsubmit and returns to a confirmation page.</p><ContactForm /></div>
    <aside><div><p>Call</p><a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></div><div><p>Write</p><address>{SITE.legalName}<br />2661 Market Street, STE 85787<br />San Francisco, CA 94114</address></div><div><p>Current materials</p><a href={EXTERNAL_LINKS.newsroom} target="_blank" rel="noopener noreferrer">Newsroom ↗</a><a href={EXTERNAL_LINKS.careers} target="_blank" rel="noopener noreferrer">LinkedIn jobs ↗</a><a href={EXTERNAL_LINKS.investorHub} target="_blank" rel="noopener noreferrer">Investor Hub ↗</a></div></aside>
  </section>
</SiteLayout>

<style>
  .contact-opening { display: grid; grid-template-columns: .35fr 1.05fr .6fr; gap: 40px; align-items: end; min-height: 610px; padding: 170px var(--page-pad) 72px; background: var(--sun); }
  .contact-opening h1 { margin: 0; font-size: clamp(5rem,10vw,10rem); }
  .contact-opening > div p { max-width: 40ch; }
  .contact-opening > div p:last-child { color: rgba(20,43,53,.65); }
  .contact-routes { display: grid; grid-template-columns: .55fr 1.45fr; gap: 70px; padding: var(--section-pad) var(--page-pad); background: var(--navy-deep); color: white; }
  .contact-routes header > p { color: var(--sun); font: 600 .66rem var(--font-mono); text-transform: uppercase; }
  .contact-routes h2 { max-width: 8ch; font-size: clamp(3.2rem,5.8vw,6rem); }
  .contact-routes > div { display: grid; grid-template-columns: repeat(2,1fr); border-top: 1px solid rgba(255,255,255,.25); border-left: 1px solid rgba(255,255,255,.25); }
  .contact-routes a { display: grid; grid-template-columns: 1fr auto; min-height: 210px; padding: 24px; border-right: 1px solid rgba(255,255,255,.25); border-bottom: 1px solid rgba(255,255,255,.25); }
  .contact-routes a > span { color: var(--sun); font: 600 .64rem var(--font-mono); text-transform: uppercase; }
  .contact-routes a > strong { grid-column: 1/3; align-self: end; font: 700 clamp(1rem,1.5vw,1.35rem) var(--font-display); }
  .contact-routes a > p { margin: 10px 0 0; color: rgba(255,255,255,.62); font-size: .88rem; }
  .contact-routes a > i { align-self: end; font-style: normal; }
  .contact-conversation { display: grid; grid-template-columns: 1.25fr .75fr; gap: clamp(50px,10vw,160px); padding: var(--section-pad) var(--page-pad); background: var(--cream); }
  .contact-conversation__form { max-width: 760px; }
  .contact-conversation h2 { max-width: 11ch; font-size: clamp(3.3rem,6vw,6.3rem); }
  .contact-conversation__form > p:nth-of-type(2) { max-width: 52ch; margin-bottom: 54px; color: var(--slate); }
  .contact-conversation aside { border-top: 2px solid var(--navy); }
  .contact-conversation aside > div { display: flex; flex-direction: column; gap: 8px; padding: 25px 0; border-bottom: 1px solid rgba(20,43,53,.3); }
  .contact-conversation aside p { color: var(--oxide); font: 600 .65rem var(--font-mono); text-transform: uppercase; }
  .contact-conversation address { font-style: normal; }
  @media (max-width: 820px) { .contact-opening, .contact-routes, .contact-conversation { grid-template-columns: 1fr; padding-inline: 20px; } .contact-opening { min-height: 600px; padding-top: 140px; } .contact-routes > div { grid-template-columns: 1fr; } }
</style>
