---
import SiteLayout from "../layouts/SiteLayout.astro";
import PartnerField from "../components/PartnerField.astro";
---

<SiteLayout title="Partners · Rangeway" description="The structures, energy, driver systems, and amenities partners enabling Rangeway." class="partner-family">
  <section class="partners-capability-opening">
    <header><p class="eyebrow eyebrow--sun">Partners / Operating system</p><h1>The experience is built together.</h1><p>Technology, infrastructure, structural, and service partners make the driver experience possible.</p></header>
    <PartnerField />
  </section>
  <section class="partners-action"><p>For technology, energy, and service partnerships.</p><a class="button button--sun" href="mailto:partners@rangeway.co?subject=Partnership%20Inquiry">partners@rangeway.co</a></section>
</SiteLayout>

<style>
  .partners-capability-opening { padding: 180px var(--page-pad) var(--section-pad); background: var(--navy-deep); color: white; }
  .partners-capability-opening > header { max-width: 980px; margin: 0 auto 58px 0; }
  .partners-capability-opening h1 { max-width: 11ch; margin: 0 0 28px; font-size: clamp(3.8rem,7vw,7.5rem); }
  .partners-capability-opening header > p:last-child { max-width: 52ch; color: rgba(255,255,255,.68); }
  .partners-action { display: flex; align-items: center; justify-content: space-between; gap: 30px; padding: 54px var(--page-pad); background: var(--oxide); color: white; }
  .partners-action p { margin: 0; font: 700 clamp(1.3rem,2.5vw,2.6rem) var(--font-display); }
  @media (max-width: 820px) { .partners-capability-opening { padding: 140px 20px 80px; } .partners-action { flex-direction: column; align-items: flex-start; padding-inline: 20px; } }
</style>
