---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { DEFAULT_DESCRIPTION, PREVIEW_NOINDEX } from "../config";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description = DEFAULT_DESCRIPTION, class: pageClass = "" } = Astro.props;
const pageFamily = pageClass.trim().split(/\s+/)[0] || "site-page";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {PREVIEW_NOINDEX && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#17313E" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Raleway:wght@500;600;700;800&family=Source+Sans+3:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class={pageClass}>
    <SiteHeader />
    <main id="main-content" class={pageClass} data-page-family={pageFamily}><slot /></main>
    <SiteFooter />
  </body>
</html>
