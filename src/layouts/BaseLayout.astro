---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  bodyClass?: string;
}

const {
  title = "Rangeway · Travel farther, stop better.",
  description = "America's first hospitality-driven EV charging network. Designed by hospitality operators, with the stop as the product.",
  image = "/images/waystation-hawaii.jpg",
  bodyClass = ""
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      /* Set before paint so reveal content only hides when JS can re-show it */
      document.documentElement.classList.add("js");
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Rangeway" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Source+Sans+3:wght@300;400;600;700&display=swap"
    />

    <script is:inline defer src="https://tinylytics.app/embed/9_N5xEnQSTdibXFSDoqf.js"></script>
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style is:global>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 12px;
        background: var(--color-ink);
        color: var(--color-cream);
        padding: 8px 14px;
        border: var(--rule) solid var(--color-warm);
        z-index: 100;
        font-family: var(--font-heading);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.78rem;
      }
      .skip-link:focus {
        top: 12px;
      }
      body {
        padding-top: 0;
      }
      body:not(.has-hero) main {
        padding-top: calc(var(--nav-height) + 24px);
      }
    </style>

    <script>
      const els = Array.from(document.querySelectorAll(".reveal"));
      const show = (el: Element) => el.classList.add("is-visible");

      if (!("IntersectionObserver" in window)) {
        els.forEach(show);
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                show(entry.target);
                obs.unobserve(entry.target);
              }
            });
          },
          // threshold 0 (any pixel) is far more reliable than a ratio gate
          { threshold: 0, rootMargin: "0px 0px -12% 0px" }
        );
        els.forEach((el) => io.observe(el));

        // Reveal anything already on screen at load (covers above-the-fold)
        const revealInView = () => {
          const vh = window.innerHeight;
          els.forEach((el) => {
            const r = el.getBoundingClientRect();
            if (r.top < vh && r.bottom > 0) show(el);
          });
        };
        window.addEventListener("load", () => requestAnimationFrame(revealInView));

        // Safety net: nothing may stay permanently hidden
        window.setTimeout(() => els.forEach(show), 2500);
      }
    </script>
  </body>
</html>
