---
import { PARTNER_GROUPS } from "../data/site-content";
---

<!-- HERO: Partner logos form an operating-system wall, with roles attached to every mark. -->
<div class="partner-field">
  {PARTNER_GROUPS.map((group, groupIndex) => (
    <section class="partner-field__group" aria-labelledby={`partner-group-${groupIndex}`}>
      <header>
        <p>Capability / 0{groupIndex + 1}</p>
        <h2 id={`partner-group-${groupIndex}`}>{group.title}</h2>
        <p>{group.promise}</p>
      </header>
      <div class="partner-field__marks">
        {group.partners.map((partner) => (
          <a href={partner.href} target="_blank" rel="noopener noreferrer" aria-label={`Visit ${partner.name}`}>
            <span class="partner-field__logo">
              <img src={partner.logo} alt={`${partner.name} logo`} width="220" height="86" loading="lazy" />
            </span>
            <span class="partner-field__identity">
              <strong>{partner.name}</strong>
              <small>{partner.role}</small>
            </span>
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </section>
  ))}
  <p class="partner-field__disclosure">
    Partner listings reflect Rangeway's current collaborations. Site-specific configurations vary by project phase.
    <a href="https://newsroom.rangeway.co" target="_blank" rel="noopener noreferrer">The Newsroom</a> carries public project announcements.
  </p>
</div>

<style>
  .partner-field { border-top: 1px solid rgba(255,255,255,.28); }
  .partner-field__group { display: grid; grid-template-columns: minmax(250px,.72fr) minmax(0,1.28fr); gap: 48px; padding: 62px 0; border-bottom: 1px solid rgba(255,255,255,.28); }
  .partner-field__group header > p:first-child { color: var(--sun); font: 500 .64rem var(--font-mono); letter-spacing: .1em; text-transform: uppercase; }
  .partner-field h2 { margin: 28px 0 18px; font-size: clamp(2.5rem,4vw,4.8rem); }
  .partner-field__group header > p:last-child { max-width: 36ch; color: rgba(255,255,255,.66); }
  .partner-field__marks { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); border-top: 1px solid rgba(255,255,255,.22); border-left: 1px solid rgba(255,255,255,.22); }
  .partner-field__marks > a { display: grid; grid-template-columns: 1fr auto; min-height: 190px; padding: 22px; border-right: 1px solid rgba(255,255,255,.22); border-bottom: 1px solid rgba(255,255,255,.22); transition: background 180ms ease, color 180ms ease; }
  .partner-field__marks > a:hover { background: var(--sun); color: var(--navy-deep); }
  .partner-field__logo { grid-column: 1/3; display: flex; min-height: 88px; align-items: center; justify-content: center; padding: 12px; background: var(--warm-white); }
  .partner-field__logo img { width: auto; max-width: 170px; height: auto; max-height: 58px; object-fit: contain; }
  .partner-field__identity { display: flex; flex-direction: column; align-self: end; gap: 3px; padding-top: 18px; }
  .partner-field__identity strong { font: 700 1rem var(--font-display); }
  .partner-field__identity small { color: rgba(255,255,255,.58); font: 500 .63rem/1.4 var(--font-mono); text-transform: uppercase; }
  .partner-field__marks > a:hover small { color: var(--navy-deep); }
  .partner-field__marks > a > span:last-child { align-self: end; }
  .partner-field__disclosure { max-width: 72ch; margin: 38px 0 0 auto; color: rgba(255,255,255,.62); font-size: .9rem; }
  .partner-field__disclosure a { color: var(--sun); text-decoration: underline; text-underline-offset: 4px; }
  @media (max-width: 820px) {
    .partner-field__group { grid-template-columns: 1fr; gap: 28px; padding: 48px 0; }
    .partner-field__marks { grid-template-columns: 1fr; }
    .partner-field__marks > a { min-height: 175px; }
  }
</style>
