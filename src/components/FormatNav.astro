---
interface Props {
  current: "waystation" | "basecamp" | "summit";
}
const { current } = Astro.props;

const formats = [
  { slug: "waystation", name: "Waystation", href: "/network/waystation" },
  { slug: "basecamp", name: "Basecamp", href: "/network/basecamp" },
  { slug: "summit", name: "Summit", href: "/network/summit" }
];
---

<nav class="format-nav" aria-label="Network formats">
  <div class="container format-nav__inner">
    <span class="format-nav__label">Explore</span>
    <ul>
      {formats.map((f) => (
        <li>
          <a href={f.href} class={current === f.slug ? "is-current" : ""}>
            {f.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .format-nav {
    background: var(--color-cream);
    border-bottom: var(--rule-bold) solid var(--color-ink);
    padding: 0;
  }

  .format-nav__inner {
    display: flex;
    align-items: center;
    gap: clamp(18px, 4vw, 54px);
    flex-wrap: wrap;
  }

  .format-nav__label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .format-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .format-nav a {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: var(--space-4) var(--space-5);
    border-left: var(--rule) solid var(--color-ink);
    border-bottom: 0;
  }

  .format-nav li:first-child a {
    border-left: 0;
  }

  .format-nav a:hover,
  .format-nav a.is-current {
    color: var(--color-ink);
    background: var(--color-warm);
  }
</style>
