---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
  image: string;
  imageAlt: string;
  align?: "left" | "center";
  scrim?: "default" | "strong";
}

const { eyebrow, title, lede, image, imageAlt, align = "left", scrim = "default" } = Astro.props;
---

<section class={`page-hero page-hero--${align} page-hero--scrim-${scrim}`}>
  <div class="page-hero__media">
    <img src={image} alt={imageAlt} fetchpriority="high" />
    <div class="page-hero__scrim"></div>
  </div>
  <div class="container page-hero__inner">
    <p class="page-hero__eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    {lede && <p class="page-hero__lede">{lede}</p>}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    color: var(--color-cream);
    min-height: 74vh;
    display: flex;
    align-items: flex-end;
    padding-top: calc(var(--nav-height) + 76px);
    padding-bottom: clamp(54px, 7vw, 102px);
    margin-top: calc(-1 * (var(--nav-height) + 24px));
    overflow: hidden;
    isolation: isolate;
    border-bottom: var(--rule-bold) solid var(--color-ink);
  }

  .page-hero--center {
    align-items: flex-end;
    text-align: left;
    min-height: 70vh;
  }

  .page-hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .page-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.02);
  }

  .page-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(23, 21, 20, 0.46) 0%, rgba(23, 21, 20, 0.26) 38%, rgba(23, 21, 20, 0.9) 100%),
      linear-gradient(90deg, rgba(23, 21, 20, 0.7) 0%, rgba(23, 21, 20, 0.26) 56%, rgba(23, 21, 20, 0.5) 100%);
  }

  .page-hero--scrim-strong .page-hero__scrim {
    background:
      linear-gradient(180deg, rgba(23, 21, 20, 0.64) 0%, rgba(23, 21, 20, 0.42) 45%, rgba(23, 21, 20, 0.94) 100%),
      linear-gradient(90deg, rgba(23, 21, 20, 0.76) 0%, rgba(23, 21, 20, 0.38) 56%, rgba(23, 21, 20, 0.62) 100%);
  }

  .page-hero--center .page-hero__inner {
    max-width: 920px;
    margin: 0;
  }

  .page-hero__inner {
    max-width: 980px;
    position: relative;
  }

  .page-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--fs-stamp);
    font-weight: 700;
    letter-spacing: var(--ls-stamp);
    text-transform: uppercase;
    line-height: 1;
    color: var(--color-warm);
    border: var(--rule) solid var(--color-warm);
    padding: 7px 11px 6px;
    margin: 0 0 var(--space-5);
  }

  .page-hero h1 {
    color: var(--color-cream);
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6.6vw, 6rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    max-width: 14ch;
  }

  .page-hero__lede {
    margin-top: var(--space-5);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.65;
    max-width: 58ch;
    opacity: 0.9;
  }

  .page-hero--center .page-hero__lede {
    margin-left: 0;
    margin-right: 0;
  }

  @media (max-width: 720px) {
    .page-hero {
      min-height: 68vh;
      padding-top: calc(var(--nav-height) + 56px);
    }

    .page-hero h1 {
      font-size: clamp(2.6rem, 13vw, 4.6rem);
      max-width: 12ch;
    }
  }
</style>
