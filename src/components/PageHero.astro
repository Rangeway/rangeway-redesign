---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
  image: string;
  imageAlt: string;
  align?: "left" | "center";
  scrim?: "default" | "strong";
}

const { eyebrow, title, lede, image, imageAlt, align = "left", scrim = "default" } = Astro.props;
---

<section class={`page-hero page-hero--${align} page-hero--scrim-${scrim}`}>
  <div class="page-hero__media">
    <img src={image} alt={imageAlt} fetchpriority="high" />
    <div class="page-hero__scrim"></div>
  </div>
  <div class="container page-hero__inner">
    <p class="page-hero__eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    {lede && <p class="page-hero__lede">{lede}</p>}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    color: var(--color-cream);
    min-height: 74vh;
    display: flex;
    align-items: flex-end;
    padding-top: calc(var(--nav-height) + 76px);
    padding-bottom: clamp(54px, 7vw, 102px);
    margin-top: calc(-1 * (var(--nav-height) + 24px));
    overflow: hidden;
    isolation: isolate;
  }

  .page-hero--center {
    align-items: flex-end;
    text-align: left;
    min-height: 70vh;
  }

  .page-hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .page-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.02);
  }

  .page-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(23, 21, 20, 0.42) 0%, rgba(23, 21, 20, 0.22) 38%, rgba(23, 21, 20, 0.9) 100%),
      linear-gradient(90deg, rgba(23, 21, 20, 0.66) 0%, rgba(23, 21, 20, 0.22) 52%, rgba(23, 21, 20, 0.5) 100%),
      radial-gradient(circle at 18% 82%, rgba(244, 168, 85, 0.2), transparent 34%);
  }

  .page-hero--scrim-strong .page-hero__scrim {
    background:
      linear-gradient(180deg, rgba(23, 21, 20, 0.62) 0%, rgba(23, 21, 20, 0.38) 45%, rgba(23, 21, 20, 0.94) 100%),
      linear-gradient(90deg, rgba(23, 21, 20, 0.72) 0%, rgba(23, 21, 20, 0.34) 52%, rgba(23, 21, 20, 0.62) 100%),
      radial-gradient(circle at 18% 82%, rgba(244, 168, 85, 0.24), transparent 38%);
  }

  .page-hero--center .page-hero__inner {
    max-width: 920px;
    margin: 0;
  }

  .page-hero__inner {
    max-width: 960px;
    position: relative;
    padding-left: clamp(20px, 3vw, 42px);
  }

  .page-hero__inner::before {
    content: "";
    position: absolute;
    left: clamp(20px, 4vw, 56px);
    top: 0.4rem;
    bottom: 0.2rem;
    width: 3px;
    background: var(--color-warm);
  }

  .page-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 700;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--color-warm);
    margin: 0 0 var(--space-4);
  }

  .page-hero__eyebrow::before {
    display: none;
  }

  .page-hero--center .page-hero__eyebrow {
    justify-content: flex-start;
  }

  .page-hero h1 {
    color: var(--color-cream);
    font-family: var(--font-heading);
    font-size: clamp(3.15rem, 7vw, 6.7rem);
    font-weight: 700;
    line-height: 0.94;
    letter-spacing: -0.06em;
    text-wrap: balance;
    max-width: 11ch;
  }

  .page-hero__lede {
    margin-top: var(--space-5);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.65;
    max-width: 58ch;
    opacity: 0.9;
  }

  .page-hero--center .page-hero__lede {
    margin-left: 0;
    margin-right: 0;
  }

  @media (max-width: 720px) {
    .page-hero {
      min-height: 68vh;
      padding-top: calc(var(--nav-height) + 56px);
    }

    .page-hero__inner {
      padding-left: clamp(20px, 4vw, 56px);
    }

    .page-hero__inner::before {
      display: none;
    }

    .page-hero h1 {
      font-size: clamp(3.2rem, 15vw, 5.2rem);
      max-width: 10ch;
    }
  }
</style>
