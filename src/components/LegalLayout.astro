---
import SiteLayout from "../layouts/SiteLayout.astro";

interface SectionLink { id: string; label: string; }
interface Props {
  title: string;
  effectiveDate: string;
  description: string;
  sections: SectionLink[];
}

const { title, effectiveDate, description, sections } = Astro.props;
---

<SiteLayout title={`${title} · Rangeway`} description={description} class="legal-family">
  <section class="legal-shell">
    <header class="legal-shell__header">
      <p>Rangeway / Legal</p>
      <h1>{title}</h1>
      <p><strong>Effective Date:</strong> {effectiveDate}</p>
    </header>
    <div class="legal-shell__grid">
      <nav aria-label="On this page">
        <p>On this page</p>
        <ol>{sections.map((section) => <li><a href={`#${section.id}`}>{section.label}</a></li>)}</ol>
      </nav>
      <article class="legal-prose"><slot /></article>
    </div>
  </section>
</SiteLayout>

<style>
  .legal-shell { padding: 170px var(--page-pad) 110px; background: var(--warm-white); }
  .legal-shell__header { max-width: 1440px; margin: 0 auto; padding-bottom: 52px; border-bottom: 2px solid var(--navy); }
  .legal-shell__header > p:first-child { color: var(--oxide); font: 600 .68rem var(--font-mono); letter-spacing: .12em; text-transform: uppercase; }
  .legal-shell h1 { max-width: 10ch; margin: 34px 0; font-size: clamp(3.6rem,8vw,8rem); }
  .legal-shell__header > p:last-child { margin: 0; color: var(--slate); }
  .legal-shell__grid { display: grid; grid-template-columns: minmax(190px,.36fr) minmax(0,1fr); gap: clamp(45px,9vw,150px); max-width: 1240px; margin: 70px auto 0; }
  .legal-shell nav { position: sticky; top: 30px; align-self: start; }
  .legal-shell nav > p { font: 600 .67rem var(--font-mono); color: var(--oxide); letter-spacing: .1em; text-transform: uppercase; }
  .legal-shell nav ol { margin: 22px 0 0; padding: 0; list-style: none; border-top: 1px solid rgba(20,43,53,.3); }
  .legal-shell nav a { display: block; padding: 9px 0; border-bottom: 1px solid rgba(20,43,53,.2); color: var(--slate); font-size: .85rem; }
  .legal-prose { max-width: 70ch; font-size: 1.05rem; line-height: 1.72; }
  .legal-prose :global(h2) { scroll-margin-top: 24px; margin: 68px 0 18px; font-size: clamp(1.55rem,2.4vw,2.3rem); line-height: 1.1; letter-spacing: -.035em; }
  .legal-prose :global(h2:first-child) { margin-top: 0; }
  .legal-prose :global(p), .legal-prose :global(ul) { margin: 0 0 24px; }
  .legal-prose :global(li) { margin-bottom: 10px; }
  .legal-prose :global(a) { color: var(--oxide); text-decoration: underline; text-underline-offset: 3px; }
  .legal-prose :global(address) { padding: 22px; border-left: 4px solid var(--sun); background: var(--cream); font-style: normal; }
  .legal-prose :global(.legal-caps) { padding: 24px; background: var(--cream); font-size: .93rem; letter-spacing: .01em; }
  @media (max-width: 820px) {
    .legal-shell { padding: 120px 20px 80px; }
    .legal-shell__grid { grid-template-columns: 1fr; gap: 42px; margin-top: 44px; }
    .legal-shell nav { position: static; }
    .legal-shell nav ol { display: grid; grid-template-columns: repeat(2,1fr); }
    .legal-shell nav li:nth-child(odd) a { border-right: 1px solid rgba(20,43,53,.2); padding-right: 10px; }
    .legal-shell nav li:nth-child(even) a { padding-left: 10px; }
    .legal-prose { max-width: 100%; font-size: 1rem; line-height: 1.65; }
  }
</style>
