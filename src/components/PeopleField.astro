---
import ResponsiveImage from "./ResponsiveImage.astro";
import { TEAM } from "../data/site-content";
---

<!-- HERO: A disciplined portrait matrix gives every member of the working team equal weight. -->
<div class="people-field">
  {TEAM.map((person, index) => (
    <article class:list={["people-field__person", `people-field__person--${index + 1}`]}>
      <div class="people-field__portrait">
        <ResponsiveImage
          src={person.image}
          srcSmall={"imageSmall" in person ? person.imageSmall : undefined}
          alt={`Portrait of ${person.name}`}
          width={person.imageWidth}
          height={person.imageHeight}
          sizes="(max-width: 720px) 100vw, (max-width: 1020px) 50vw, 33vw"
          position={index === 1 ? "50% 28%" : "center 22%"}
        />
        <span aria-hidden="true">0{index + 1}</span>
      </div>
      <div class="people-field__copy">
        <p>{person.role}</p>
        <h2>{person.name}</h2>
        <p>{person.bio}</p>
        <a href={person.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${person.name} on LinkedIn`}>
          LinkedIn <span aria-hidden="true">↗</span>
        </a>
      </div>
    </article>
  ))}
</div>

<style>
  .people-field { display: grid; grid-template-columns: repeat(6,minmax(0,1fr)); gap: clamp(64px, 7vw, 104px) 28px; max-width: 1320px; margin-inline: auto; }
  .people-field__person { grid-column: span 2; min-width: 0; }
  .people-field__person--4 { grid-column: 2 / span 2; }
  .people-field__person--5 { grid-column: 4 / span 2; }
  .people-field__portrait { position: relative; aspect-ratio: .82; background: var(--cream); overflow: hidden; }
  :global(.people-field__portrait img) { filter: grayscale(1); }
  .people-field__portrait::after { content: ""; position: absolute; inset: 0; box-shadow: inset 0 0 0 1px rgba(20,43,53,.18); pointer-events: none; }
  .people-field__portrait > span { position: absolute; right: 0; bottom: 0; min-width: 68px; padding: 14px; background: var(--sun); color: var(--navy-deep); font: 600 .72rem var(--font-mono); text-align: center; }
  .people-field__copy { display: grid; grid-template-columns: minmax(110px,.38fr) 1fr; gap: 8px 24px; padding: 24px 0 0; border-top: 2px solid var(--navy); }
  .people-field__copy > p:first-child { grid-row: 1/3; color: var(--oxide); font: 600 .66rem/1.4 var(--font-mono); letter-spacing: .08em; text-transform: uppercase; }
  .people-field h2 { margin: 0; font-size: clamp(2rem,3.6vw,4rem); }
  .people-field__copy > p:nth-of-type(2) { max-width: 48ch; margin: 8px 0 14px; color: var(--slate); }
  .people-field a { grid-column: 2; width: fit-content; padding-bottom: 5px; border-bottom: 1px solid currentColor; font: 700 .7rem var(--font-display); letter-spacing: .07em; text-transform: uppercase; }
  @media (max-width: 1020px) and (min-width: 821px) {
    .people-field { grid-template-columns: repeat(2,minmax(0,1fr)); max-width: 900px; }
    .people-field__person, .people-field__person--4 { grid-column: auto; }
    .people-field__person--5 { grid-column: 1 / -1; width: min(100%,420px); justify-self: center; }
  }
  @media (max-width: 820px) {
    .people-field { display: block; }
    .people-field__person { margin-bottom: 68px; }
    .people-field__copy { grid-template-columns: 1fr; }
    .people-field__copy > p:first-child { grid-row: auto; }
    .people-field a { grid-column: auto; }
  }
</style>
