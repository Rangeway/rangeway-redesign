---
interface Props {
  name: string;
  tagline: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  pill?: string;
  compact?: boolean;
}
const { name, tagline, description, image, imageAlt, href, pill, compact = false } = Astro.props;
---

<a class={`fmt-card reveal${compact ? " fmt-card--compact" : ""}`} href={href}>
  <div class="fmt-card__media">
    <img src={image} alt={imageAlt} loading="lazy" />
    {pill && <span class="fmt-card__pill">{pill}</span>}
  </div>
  <div class="fmt-card__body">
    <p class="fmt-card__eyebrow">{tagline}</p>
    <h3>{name}</h3>
    {!compact && <p class="fmt-card__description">{description}</p>}
    {!compact && (
      <div class="fmt-card__foot">
        <span class="arrow-link">
          Learn more
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </span>
      </div>
    )}
  </div>
</a>

<style>
  .fmt-card {
    background: var(--surface-raised);
    border: var(--rule) solid var(--color-ink);
    border-radius: 0;
    display: grid;
    grid-template-columns: minmax(220px, 0.92fr) minmax(0, 1.08fr);
    color: var(--color-text);
    transition: transform var(--dur-med) var(--ease-standard),
      box-shadow var(--dur-med) var(--ease-standard);
    box-shadow: 0 0 0 var(--color-ink);
  }

  .fmt-card:hover {
    transform: translate(-5px, -5px);
    box-shadow: var(--shadow-hard);
    color: var(--color-text);
  }

  .fmt-card__media {
    position: relative;
    isolation: isolate;
    min-height: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-ink);
    border-right: var(--rule) solid var(--color-ink);
  }

  .fmt-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.06) brightness(0.96);
    mix-blend-mode: luminosity;
  }

  /* Amber duotone at rest; blooms to full color on hover */
  .fmt-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: var(--color-warm);
    mix-blend-mode: multiply;
    opacity: 0.6;
    transition: opacity var(--dur-med) var(--ease-standard);
  }

  .fmt-card:hover .fmt-card__media img {
    filter: none;
    mix-blend-mode: normal;
  }

  .fmt-card:hover .fmt-card__media::after {
    opacity: 0;
  }

  /* No hover (touch): show full color, no duotone to get stuck in */
  @media (hover: none) {
    .fmt-card__media img {
      filter: none;
      mix-blend-mode: normal;
    }
    .fmt-card__media::after {
      opacity: 0;
    }
  }

  .fmt-card__pill {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    padding: 8px 12px;
    background: var(--color-warm);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-right: var(--rule) solid var(--color-ink);
    border-bottom: var(--rule) solid var(--color-ink);
  }

  .fmt-card__body {
    padding: clamp(24px, 3.5vw, 42px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-4);
    flex: 1;
  }

  .fmt-card__eyebrow {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-warm-deep);
    margin: 0;
  }

  .fmt-card h3 {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 0.96;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
  }

  .fmt-card__description {
    color: var(--color-text-muted);
    font-size: 1.03rem;
    line-height: 1.7;
    margin: 0;
  }

  .fmt-card__foot {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .fmt-card__foot .arrow-link {
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .fmt-card:hover .fmt-card__foot .arrow-link {
    color: var(--color-warm-deep);
  }

  .fmt-card:hover .fmt-card__foot .arrow-link svg {
    transform: translateX(3px);
  }

  .fmt-card--compact {
    min-height: 360px;
  }

  .fmt-card--compact .fmt-card__body {
    padding: clamp(22px, 3vw, 34px);
  }

  .fmt-card--compact .fmt-card__media {
    aspect-ratio: 1 / 1;
  }

  @media (max-width: 760px) {
    .fmt-card {
      grid-template-columns: 1fr;
    }

    .fmt-card__media,
    .fmt-card--compact .fmt-card__media {
      aspect-ratio: 16 / 10;
      min-height: 0;
    }
  }
</style>
