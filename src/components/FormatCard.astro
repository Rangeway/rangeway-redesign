---
interface Props {
  name: string;
  tagline: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  pill?: string;
  compact?: boolean;
}
const { name, tagline, description, image, imageAlt, href, pill, compact = false } = Astro.props;
---

<a class={`fmt-card reveal${compact ? " fmt-card--compact" : ""}`} href={href}>
  <div class="fmt-card__media">
    <img src={image} alt={imageAlt} loading="lazy" />
    {pill && <span class="fmt-card__pill">{pill}</span>}
  </div>
  <div class="fmt-card__body">
    <p class="fmt-card__eyebrow">{tagline}</p>
    <h3>{name}</h3>
    {!compact && <p class="fmt-card__description">{description}</p>}
    {!compact && (
      <div class="fmt-card__foot">
        <span class="arrow-link">
          Learn more
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </span>
      </div>
    )}
  </div>
</a>

<style>
  .fmt-card {
    overflow: hidden;
    background: rgba(251, 247, 241, 0.62);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    display: grid;
    grid-template-columns: minmax(220px, 0.92fr) minmax(0, 1.08fr);
    color: var(--color-text);
    transition: transform var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      background var(--dur-med) var(--ease-standard);
  }

  .fmt-card:hover {
    transform: translateY(-3px);
    border-color: rgba(232, 146, 58, 0.48);
    background: rgba(251, 247, 241, 0.82);
    color: var(--color-text);
  }

  .fmt-card__media {
    position: relative;
    min-height: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--surface-alt);
  }

  .fmt-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .fmt-card:hover .fmt-card__media img {
    transform: scale(1.04);
  }

  .fmt-card__pill {
    position: absolute;
    top: 14px;
    left: 14px;
    padding: 7px 10px;
    border-radius: var(--radius-sm);
    background: rgba(24, 21, 20, 0.7);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .fmt-card__body {
    padding: clamp(24px, 3.5vw, 42px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-4);
    flex: 1;
  }

  .fmt-card__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--color-warm-deep);
    margin: 0;
  }

  .fmt-card h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.9rem, 3vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
    color: var(--color-text);
    margin: 0;
  }

  .fmt-card__description {
    color: var(--color-text-muted);
    font-size: 1.03rem;
    line-height: 1.7;
    margin: 0;
  }

  .fmt-card__foot {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .fmt-card__foot .arrow-link {
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .fmt-card:hover .fmt-card__foot .arrow-link {
    color: var(--color-warm-deep);
  }

  .fmt-card:hover .fmt-card__foot .arrow-link svg {
    transform: translateX(3px);
  }

  .fmt-card--compact {
    min-height: 360px;
  }

  .fmt-card--compact .fmt-card__body {
    padding: clamp(22px, 3vw, 34px);
  }

  .fmt-card--compact .fmt-card__media {
    aspect-ratio: 1 / 1;
  }

  @media (max-width: 760px) {
    .fmt-card {
      grid-template-columns: 1fr;
    }

    .fmt-card__media,
    .fmt-card--compact .fmt-card__media {
      aspect-ratio: 16 / 10;
      min-height: 0;
    }
  }
</style>
