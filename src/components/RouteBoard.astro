---
import { PROJECTS } from "../data/site-content";
---

<section class="route-board" aria-labelledby="route-board-title">
  <div class="route-board__head">
    <div>
      <p class="eyebrow eyebrow--sun">Public projects · west to east</p>
      <h2 id="route-board-title">See where<br />we’re building.</h2>
    </div>
    <p>
      Three public regions. One operating standard: treat the charging stop as part of the trip,
      then show the work as it takes shape.
    </p>
  </div>

  <ol class="route-board__list">
    {PROJECTS.map((project, index) => (
      <li class="route-board__row">
        <span class="route-board__node" aria-hidden="true"><i></i></span>
        <p class="route-board__number">0{index + 1}</p>
        <div class="route-board__place">
          <h3>{project.place}</h3>
          <p>{project.region}</p>
        </div>
        <p class="route-board__corridor">{project.corridor}</p>
        <p class="route-board__activity">{project.activity}</p>
        <a href={project.href} target="_blank" rel="noopener noreferrer" aria-label={`${project.linkLabel}, opens in a new tab`}>
          View <span aria-hidden="true">↗</span>
        </a>
      </li>
    ))}
  </ol>
</section>
